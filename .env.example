AI_BACKEND=auto
AI_PROVIDER_NAME=openai-compatible
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-v4-pro
AI_TIMEOUT_MS=60000
AI_API_KEY=your-api-key-here

# The packaged desktop app pins its embedded Reasonix runtime to DeepSeek's
# official endpoint, deepseek-v4-pro, and max reasoning effort. These values are
# release-controlled and are intentionally not configurable through env vars.

# Hosted deployments: keep anonymous analyst access for the public demo, or set
# this to 0 and issue a separate analyst bearer token. Never commit real values.
COFORGE_DEMO_ANONYMOUS=1
COFORGE_ALLOWED_ORIGINS=https://your-demo.example
COFORGE_ANALYST_TOKEN=replace-with-a-random-analyst-token
COFORGE_ADMIN_TOKEN=replace-with-a-different-random-admin-token

# Set only when a controlled reverse proxy strips client-supplied forwarding
# headers and writes its own X-Forwarded-For/Host/Proto values.
COFORGE_TRUST_PROXY=0

# Only the desktop wrapper should set COFORGE_DESKTOP and its per-process
# capability. Private/LAN model endpoints require an explicit desktop opt-in.
COFORGE_ALLOW_PRIVATE_PROVIDER=0
